{
  "$schema": "https://www.schemastore.org/claude-code-settings.json",

  "//": "Default permission mode. Uncomment 'auto' to enable autonomous mode (classifier + sandbox). Source: /engineering/claude-code-auto-mode — FPR drops from 8.5% to 0.4% vs liberal denial.",
  "//defaultMode": "auto",

  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Edit(./__tests__/**)",
      "Edit(./docs/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(npm publish *)",
      "Bash(git push *)",
      "Bash(gh auth *)",
      "Edit(./.env*)",
      "Edit(./db/migrations/**)",
      "Edit(./vendor/**)",
      "Edit(./node_modules/**)",
      "Read(./.env*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint --silent || true",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "//": "Belt-and-suspenders example: the deny rule above already blocks git push without a prompt. This hook is here as a syntax demonstration of PreToolUse blocking — it would be useful for finer-grained matchers (e.g. blocking `git push origin main` while allowing `git push origin feat/*`).",
        "matcher": "Bash(git push *)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Push blocked by hook — humans push, not Claude.' && exit 1"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowRead": ["./", "~/.cache"],
      "allowWrite": ["./"],
      "denyRead": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.config/gh", "/etc"],
      "denyWrite": ["~/.ssh", "~/.aws", "~/.gnupg", "/etc"]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "github.com",
        "api.github.com",
        "api.anthropic.com"
      ]
    }
  },

  "//env": "ANTHROPIC_LOG below is consumed by the Anthropic Python SDK (used by evals/run.py and judge.py), NOT by Claude Code itself. Remove this block if you don't run the eval harness locally.",
  "env": {
    "ANTHROPIC_LOG": "info"
  }
}
